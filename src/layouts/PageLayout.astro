---
import BaseLayout from './BaseLayout.astro';
import BreadcrumbNav from '../components/BreadcrumbNav.astro';
import FAQSection from '../components/FAQSection.astro';

interface BreadcrumbItem { name: string; item: string; }
interface FAQItem { question: string; answer: string; }

interface Props {
  title: string;
  description: string;
  canonical: string;
  schema?: Record<string, unknown>;
  andar?: 'roxo' | 'gold' | 'orange' | 'gray' | 'red' | 'none';
  activePath?: string;
  lcpImage?: string;
  ogImage?: string;
  isYMYL?: boolean;
  breadcrumb?: BreadcrumbItem[];
  faqItems?: FAQItem[];
  h1: string;
}

const {
  title, description, canonical, schema,
  andar = 'none', activePath = '',
  lcpImage, ogImage, isYMYL = false,
  breadcrumb = [], faqItems = [], h1,
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  schema={schema}
  andar={andar}
  activePath={activePath}
  lcpImage={lcpImage}
  ogImage={ogImage}
  isYMYL={isYMYL}
>
  <div class="page-content">
    <div class="wrap page-wrap">
      {breadcrumb.length > 0 && <BreadcrumbNav items={breadcrumb} />}

      <article>
        <header class="page-header-inline">
          <h1 class="page-h1" set:html={h1} />
        </header>

        <div class="prose">
          <slot />
        </div>
      </article>

      {faqItems.length > 0 && (
        <FAQSection items={faqItems} andar={andar === 'none' ? 'roxo' : andar} />
      )}
    </div>
  </div>
</BaseLayout>

<style>
.page-content { padding: var(--sp-10) 0 var(--sp-16); }
.page-wrap { max-width: 820px; }
.page-header-inline { margin-bottom: 32px; }
.page-h1 {
  font-family: var(--font-display); font-size: clamp(26px, 3.5vw, 42px);
  font-weight: 400; line-height: 1.1; color: var(--text);
}
</style>
