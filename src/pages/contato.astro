---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiloHero   from '../components/SiloHero.astro';
import BreadcrumbNav from '../components/BreadcrumbNav.astro';

const WA_NUMBER  = '5531991070392';
const WA_AGENDA  = `https://wa.me/${WA_NUMBER}?text=${encodeURIComponent('Olá! Gostaria de agendar minha aula-avaliação gratuita no Studio Livel.')}`;

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["HealthClub","LocalBusiness"],
      "@id": "https://studiotreinointeligente.com.br/#organization",
      "name": "Studio Livel Treino Inteligente",
      "url": "https://studiotreinointeligente.com.br/",
      "telephone": "+55-31-99107-0392",
      "foundingDate": "1986",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "R. Chopin, 271",
        "addressLocality": "Belo Horizonte",
        "addressRegion": "MG",
        "postalCode": "30410-180",
        "addressCountry": "BR"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": -19.9350,
        "longitude": -43.9480
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
          "opens": "06:30", "closes": "21:00"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": "Saturday",
          "opens": "07:00", "closes": "13:00"
        }
      ]
    },
    {
      "@type": "ContactPage",
      "@id": "https://studiotreinointeligente.com.br/contato/#webpage",
      "url": "https://studiotreinointeligente.com.br/contato/",
      "name": "Contato | Studio Livel Treino Inteligente",
      "inLanguage": "pt-BR",
      "isPartOf": { "@id": "https://studiotreinointeligente.com.br/#website" }
    }
  ]
};

const breadcrumb = [
  { name: "Início",  item: "https://studiotreinointeligente.com.br/" },
  { name: "Contato", item: "https://studiotreinointeligente.com.br/contato/" },
];
---

<BaseLayout
  title="Contato | Studio Livel Treino Inteligente"
  description="Fale com o Studio Livel: WhatsApp, formulário, endereço e mapa. R. Chopin, 271, Prado, Belo Horizonte. Aula-avaliação gratuita em 50 minutos."
  canonical="https://studiotreinointeligente.com.br/contato/"
  schema={schema}
  andar="roxo"
  activePath="/contato/"
>

  <!-- ── DOBRA 1: HERO ──────────────────────────────── -->
  <SiloHero
    overline="Contato · Prado, BH"
    h1="Fale com o Studio Livel"
    intro="Estamos na R. Chopin, 271, Prado, Belo Horizonte. Agende sua aula-avaliação gratuita ou tire dúvidas pelo formulário abaixo."
    andar="roxo"
    ctaHref={WA_AGENDA}
    ctaLabel="Agendar pelo WhatsApp"
    ctaSecondaryHref="#mapa"
    ctaSecondaryLabel="Ver localização"
    stats={[
      { num: '1986',   label: 'Em operação desde' },
      { num: '50 min', label: 'Aula-Avaliação grátis' },
      { num: 'Prado',  label: 'Localização' },
    ]}
  />

  <div class="contato-body">

    <!-- ── DOBRA 2: BREADCRUMB + SUMÁRIO ─────────────── -->
    <section class="dobra-sumario">
      <div class="wrap">
        <BreadcrumbNav items={breadcrumb} />
        <p class="sumario-text">
          <strong>Studio Livel Treino Inteligente.</strong> R. Chopin, 271, Prado, BH.
          Fale por WhatsApp, preencha o formulário ou apareça pessoalmente nos nossos
          horários de atendimento. A aula-avaliação de 50 min é gratuita e sem compromisso.
        </p>
      </div>
    </section>

    <!-- ── DOBRA 3: FORMULÁRIO + INFO ────────────────── -->
    <section class="dobra-contato" aria-labelledby="form-heading">
      <div class="wrap contato-grid">

        <!-- Formulário -->
        <div class="form-col">
          <h2 id="form-heading" class="contato-h2">Enviar mensagem</h2>
          <p class="contato-sub">
            Preencha os campos abaixo. Ao clicar em enviar, você será
            redirecionado para o WhatsApp com a mensagem já preenchida.
          </p>

          <form id="contato-form" class="contato-form" novalidate>
            <div class="form-field">
              <label for="cf-nome">Nome completo <span class="req" aria-hidden="true">*</span></label>
              <input id="cf-nome" name="nome" type="text" required
                     placeholder="Seu nome completo" autocomplete="name" />
              <span class="form-err" id="err-nome">Por favor, informe seu nome.</span>
            </div>

            <div class="form-field">
              <label for="cf-tel">Telefone / WhatsApp <span class="req" aria-hidden="true">*</span></label>
              <input id="cf-tel" name="tel" type="tel" required
                     placeholder="(31) 9 0000-0000" autocomplete="tel" />
              <span class="form-err" id="err-tel">Por favor, informe seu telefone.</span>
            </div>

            <div class="form-field">
              <label for="cf-modal">Modalidade de interesse</label>
              <select id="cf-modal" name="modal">
                <option value="">Selecione (opcional)</option>
                <option value="Pilates">Pilates</option>
                <option value="Musculação">Musculação</option>
                <option value="Treino Funcional / FitBox">Treino Funcional / FitBox</option>
                <option value="Yoga">Yoga</option>
                <option value="Krav Magá">Krav Magá</option>
                <option value="Ainda não decidi">Ainda não decidi</option>
              </select>
            </div>

            <div class="form-field">
              <label for="cf-msg">Mensagem <span class="req" aria-hidden="true">*</span></label>
              <textarea id="cf-msg" name="msg" rows="4" required
                        placeholder="Dúvidas sobre horários, planos, modalidades..."></textarea>
              <span class="form-err" id="err-msg">Por favor, escreva sua mensagem.</span>
            </div>

            <button type="submit" class="btn btn--roxo btn--lg contato-submit">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                <path d="M12 0C5.373 0 0 5.373 0 12c0 2.025.504 3.94 1.39 5.617L0 24l6.545-1.367A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.797 9.797 0 01-5.031-1.388l-.36-.214-3.732.979.997-3.648-.235-.374A9.786 9.786 0 012.182 12C2.182 6.57 6.57 2.182 12 2.182c5.43 0 9.818 4.388 9.818 9.818 0 5.43-4.388 9.818-9.818 9.818z" fill-rule="evenodd"/>
              </svg>
              Enviar pelo WhatsApp
            </button>

            <p class="form-note">
              Seus dados são usados apenas para montar a mensagem no WhatsApp.
              Nenhuma informação é armazenada nos nossos servidores.
            </p>
          </form>
        </div>

        <!-- Info -->
        <aside class="info-col" aria-label="Informações de contato">

          <div class="info-card">
            <div class="info-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div>
              <h3 class="info-label">Endereço</h3>
              <p class="info-value">
                R. Chopin, 271<br />
                Prado, Belo Horizonte, MG<br />
                CEP 30410-180
              </p>
              <a href="#mapa" class="info-link">Ver no mapa ↓</a>
            </div>
          </div>

          <div class="info-card">
            <div class="info-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.15 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.07 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
            </div>
            <div>
              <h3 class="info-label">Telefone / WhatsApp</h3>
              <a href="tel:+5531991070392" class="info-phone">(31) 99107-0392</a>
              <a href={WA_AGENDA} target="_blank" rel="noopener noreferrer" class="info-wa-btn">
                Abrir no WhatsApp →
              </a>
            </div>
          </div>

          <div class="info-card">
            <div class="info-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <div>
              <h3 class="info-label">Horários</h3>
              <table class="info-table">
                <tbody>
                  <tr><td>Seg – Sex</td><td>06h30 – 21h00</td></tr>
                  <tr><td>Sábado</td><td>07h00 – 13h00</td></tr>
                  <tr><td>Dom e Feriados</td><td>Fechado</td></tr>
                </tbody>
              </table>
            </div>
          </div>

          <div class="info-card">
            <div class="info-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
              </svg>
            </div>
            <div>
              <h3 class="info-label">Redes sociais</h3>
              <div class="info-socials">
                <a href="https://www.instagram.com/livelestudio/" target="_blank" rel="noopener noreferrer" class="social-pill">Instagram</a>
                <a href="https://www.facebook.com/studiolivel/"   target="_blank" rel="noopener noreferrer" class="social-pill">Facebook</a>
              </div>
            </div>
          </div>

          <div class="info-card info-partners-card">
            <h3 class="info-label">Aceita convênios</h3>
            <div class="partners-row">
              <span class="partner-tag">Wellhub (Gympass)</span>
              <span class="partner-tag">TotalPass</span>
              <span class="partner-tag">ClassPass</span>
            </div>
            <a href="/wellhub-totalpass-classpass/" class="info-link">Saiba mais sobre convênios →</a>
          </div>

        </aside>
      </div>
    </section>

    <!-- ── DOBRA 4: MAPA ───────────────────────────────── -->
    <section id="mapa" class="dobra-mapa" aria-labelledby="mapa-heading">
      <div class="wrap mapa-header">
        <p class="dobra-kicker" style="color:var(--roxo)">Como chegar</p>
        <h2 id="mapa-heading" class="dobra-h2">R. Chopin, 271, Prado, Belo Horizonte</h2>
      </div>
      <div class="mapa-embed-wrap">
        <iframe
          title="Localização do Studio Livel: R. Chopin, 271, Prado, BH"
          src="https://maps.google.com/maps?q=R.+Chopin,+271,+Prado,+Belo+Horizonte,+MG,+30410-180&output=embed&z=16&hl=pt-BR"
          width="100%"
          height="440"
          style="border:0;display:block;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
      <div class="wrap mapa-cta">
        <a
          href="https://www.google.com/maps/dir/?api=1&destination=R.+Chopin,+271,+Prado,+Belo+Horizonte,+MG"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn--outline-dark"
        >
          Abrir rotas no Google Maps →
        </a>
      </div>
    </section>

    <!-- ── DOBRA 5: TEXTO SEO EXPANDÍVEL ─────────────── -->
    <section class="dobra-seo-contato">
      <div class="wrap">
        <div class="fade-expand-wrap">
          <div class="fade-expand" id="ce-expand">
            <div class="fade-expand__prose prose">
              <p>
                <strong>Studio Livel Treino Inteligente</strong> está localizado na R. Chopin, 271,
                Prado, Belo Horizonte, MG, CEP 30410-180, em operação contínua desde 1986.
                O estúdio ocupa dois andares: o térreo com vestiários e recepção, o primeiro andar
                com a sala de Musculação, Treino Funcional e FitBox, e o segundo andar com a sala
                de Pilates com equipamentos Reformer, Cadillac e Chair.
              </p>
              <h2>Como funciona o agendamento</h2>
              <p>
                O contato é feito diretamente pelo WhatsApp <a href="tel:+5531991070392">(31) 99107-0392</a>.
                A primeira sessão no estúdio é sempre a <strong>Aula-Avaliação gratuita</strong> de 50 minutos,
                durante a qual o educador físico mapeia histórico de lesões, mobilidade, objetivos e
                experiência prévia. Ao final, o aluno recebe a indicação de qual modalidade, qual
                frequência e qual plano fazem mais sentido.
              </p>
              <h2>Modalidades disponíveis</h2>
              <p>
                O Studio Livel oferece <strong>Pilates</strong> (2º andar, equipamentos, turmas de até 6
                alunos por professor), <strong>Musculação</strong> (1º andar, periodização Método Livel),
                <strong>Treino Funcional e FitBox</strong> (1º andar, kit de elásticos inteligentes),
                <strong>Yoga</strong> e <strong>Krav Magá</strong>.
                Todas as modalidades seguem ciclos de 3 semanas do Método Livel.
              </p>
              <h2>Convênios e parcerias</h2>
              <p>
                O Studio Livel aceita alunos via <strong>Wellhub (Gympass)</strong>,
                <strong>TotalPass</strong> e <strong>ClassPass</strong>.
                Para acesso por convênio, consulte o plano disponível para a sua modalidade de
                interesse na <a href="/wellhub-totalpass-classpass/">página de parcerias</a>.
                O estúdio não atende por convênio de plano de saúde.
              </p>
              <h2>Área de atendimento</h2>
              <p>
                O estúdio atende alunos do Prado e de 12 bairros num raio de 5 km:
                Padre Eustáquio, Caiçara, Barro Preto, Santo Agostinho, Barroca, Alto Barroca,
                Carlos Prates, Califórnia, Calafate, Gutierrez e Nova Suíça.
                Consulte a página de cada modalidade para ver as páginas específicas por bairro.
              </p>
            </div>
            <div class="fade-expand__veil" aria-hidden="true"></div>
          </div>
          <button class="fade-expand__btn" id="ce-btn" type="button">
            <span id="ce-btn-label">Ler mais</span>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true" id="ce-btn-icon">
              <path d="M2.5 5L7 9.5L11.5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
      </div>
    </section>

  </div>
</BaseLayout>

<!-- ── SCRIPTS ─────────────────────────────────────── -->
<script is:inline>
/* --- Formulário → WhatsApp --- */
(function () {
  var WA = 'https://wa.me/5531991070392?text=';

  var form  = document.getElementById('contato-form');
  if (!form) return;

  function field(id) { return document.getElementById(id); }
  function showErr(id, show) {
    var el = document.getElementById(id);
    if (el) el.style.display = show ? 'block' : 'none';
  }

  form.addEventListener('submit', function (e) {
    e.preventDefault();
    var nome  = field('cf-nome').value.trim();
    var tel   = field('cf-tel').value.trim();
    var modal = field('cf-modal').value;
    var msg   = field('cf-msg').value.trim();

    var ok = true;
    showErr('err-nome', !nome); if (!nome) ok = false;
    showErr('err-tel',  !tel);  if (!tel)  ok = false;
    showErr('err-msg',  !msg);  if (!msg)  ok = false;
    if (!ok) return;

    var text = 'Olá! Meu nome é ' + nome + ', meu telefone é ' + tel + '.';
    if (modal) text += ' Tenho interesse em ' + modal + '.';
    text += ' ' + msg;

    window.open(WA + encodeURIComponent(text), '_blank');
  });

  /* Limpa erro ao digitar */
  ['cf-nome','cf-tel','cf-msg'].forEach(function (id) {
    var el = field(id);
    if (el) el.addEventListener('input', function () {
      showErr('err-' + id.replace('cf-',''), false);
    });
  });
}());

/* --- Expand / Collapse texto SEO --- */
(function () {
  var wrap  = document.getElementById('ce-expand');
  var btn   = document.getElementById('ce-btn');
  var label = document.getElementById('ce-btn-label');
  var icon  = document.getElementById('ce-btn-icon');
  if (!wrap || !btn) return;

  var veil    = wrap.querySelector('.fade-expand__veil');
  var prose   = wrap.querySelector('.fade-expand__prose');
  var expanded = false;

  btn.addEventListener('click', function () {
    expanded = !expanded;
    if (expanded) {
      wrap.style.transition = 'max-height 0.45s ease';
      wrap.style.maxHeight  = prose.scrollHeight + 'px';
      if (veil) veil.style.opacity = '0';
      label.textContent = 'Ler menos';
      icon.style.transform = 'rotate(180deg)';
      setTimeout(function () {
        wrap.style.maxHeight = 'none';
        wrap.style.overflow  = 'visible';
      }, 460);
    } else {
      wrap.style.overflow   = 'hidden';
      wrap.style.maxHeight  = prose.scrollHeight + 'px';
      wrap.style.transition = 'max-height 0.35s ease';
      requestAnimationFrame(function () {
        wrap.style.maxHeight = '120px';
      });
      if (veil) veil.style.opacity = '1';
      label.textContent = 'Ler mais';
      icon.style.transform = 'rotate(0deg)';
    }
  });
}());
</script>

<style>
/* ── Layout geral ─────────────────────────────────── */
.contato-body { background: #fff; }
.dobra-kicker { font-size: 11px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; margin-bottom: 10px; }
.dobra-h2 { font-family: var(--font-display); font-size: clamp(22px,2.8vw,34px); font-weight: 400; color: var(--text); margin-bottom: 32px; line-height: 1.15; }

/* ── Dobra 2: Sumário ─────────────────────────────── */
.dobra-sumario { padding: 36px 0 0; }
.sumario-text {
  font-size: 16.5px; font-weight: 500; color: var(--text);
  border-left: 4px solid var(--roxo, #632465); padding: 18px 24px;
  background: color-mix(in srgb, var(--roxo, #632465) 8%, white);
  border-radius: 0 var(--r-lg) var(--r-lg) 0;
  margin: 0 0 8px; line-height: 1.78; max-width: 820px;
}

/* ── Dobra 3: Form + Info ─────────────────────────── */
.dobra-contato { padding: 52px 0 60px; }
.contato-grid {
  display: grid;
  grid-template-columns: 1fr 420px;
  gap: 56px;
  align-items: start;
}
@media (max-width: 960px) {
  .contato-grid { grid-template-columns: 1fr; gap: 40px; }
}

/* Formulário */
.contato-h2 {
  font-family: var(--font-display); font-size: clamp(20px,2.4vw,28px);
  font-weight: 400; color: var(--text); margin-bottom: 8px;
}
.contato-sub { font-size: 14.5px; color: var(--text-dim); line-height: 1.6; margin-bottom: 28px; }

.contato-form { display: flex; flex-direction: column; gap: 18px; }
.form-field { display: flex; flex-direction: column; gap: 6px; }
.form-field label {
  font-size: 13.5px; font-weight: 600; color: var(--text);
}
.req { color: var(--roxo, #632465); }
.form-field input,
.form-field select,
.form-field textarea {
  border: 1.5px solid var(--border, #DDD);
  border-radius: var(--r-md, 8px);
  padding: 11px 14px;
  font-size: 14.5px;
  color: var(--text);
  background: #fff;
  transition: border-color .15s, box-shadow .15s;
  font-family: inherit;
  width: 100%;
  box-sizing: border-box;
}
.form-field input:focus,
.form-field select:focus,
.form-field textarea:focus {
  outline: none;
  border-color: var(--roxo, #632465);
  box-shadow: 0 0 0 3px color-mix(in srgb, var(--roxo, #632465) 14%, transparent);
}
.form-field textarea { resize: vertical; min-height: 100px; }
.form-err {
  display: none;
  font-size: 12.5px;
  color: #c0392b;
  font-weight: 500;
}

.contato-submit {
  display: flex; align-items: center; justify-content: center;
  gap: 10px; width: 100%;
}
.form-note {
  font-size: 12px; color: var(--text-dim); line-height: 1.5;
  text-align: center; margin-top: 4px;
}

/* Info sidebar */
.info-col { display: flex; flex-direction: column; gap: 2px; }

.info-card {
  display: flex; gap: 14px; align-items: flex-start;
  padding: 20px 0;
  border-bottom: 1px solid var(--border, #E8E4DE);
}
.info-card:last-child { border-bottom: none; }
.info-icon {
  width: 40px; height: 40px; flex-shrink: 0;
  background: color-mix(in srgb, var(--roxo, #632465) 10%, white);
  border-radius: var(--r-md, 8px);
  display: flex; align-items: center; justify-content: center;
  color: var(--roxo, #632465);
  margin-top: 2px;
}
.info-label {
  font-size: 11px; font-weight: 700; letter-spacing: .1em;
  text-transform: uppercase; color: var(--text-dim);
  margin-bottom: 6px;
}
.info-value { font-size: 14.5px; color: var(--text); line-height: 1.65; margin-bottom: 6px; }
.info-phone {
  display: block; font-size: 20px; font-weight: 700;
  color: var(--text); text-decoration: none;
