---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQSection from '../components/FAQSection.astro';

// Schema da home
const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': ['HealthClub','Organization'],
      '@id': 'https://studiotreinointeligente.com.br/#organization',
      'name': 'Studio Livel Treino Inteligente',
      'url': 'https://studiotreinointeligente.com.br/',
      'foundingDate': '1986',
      'description': 'Casa especializada em treino acompanhado no Prado, Belo Horizonte, em operacao continua desde 1986.',
      'address': { '@type': 'PostalAddress', 'streetAddress': 'R. Chopin, 271', 'addressLocality': 'Belo Horizonte', 'addressRegion': 'MG', 'postalCode': '30410-180', 'addressCountry': 'BR' },
      'telephone': '+55-31-99107-0392',
      'aggregateRating': { '@type': 'AggregateRating', 'ratingValue': '4.8', 'reviewCount': '201', 'bestRating': '5', 'worstRating': '1' },
      'logo': {
        '@type': 'ImageObject',
        'url': 'https://studiotreinointeligente.com.br/images/logos/logo-livel-studio-roxa.png',
        'width': 140,
        'height': 140,
      },
      'sameAs': [
        'https://share.google/6dkQeAfPyaZqeFEIX',
        'https://www.instagram.com/livelestudio/',
        'https://www.facebook.com/studiolivel/',
      ],
      'knowsAbout': [
        { '@type': 'Thing', '@id': 'https://www.wikidata.org/wiki/Q182150', 'name': 'Pilates' },
        { '@type': 'Thing', '@id': 'https://www.wikidata.org/wiki/Q8162',   'name': 'Yoga' },
        { '@type': 'Thing', '@id': 'https://www.wikidata.org/wiki/Q193208', 'name': 'Krav Magá' },
        { '@type': 'Thing', 'name': 'Musculação' },
        { '@type': 'Thing', 'name': 'Treino Funcional' },
      ],
      'hasPart': [
        { '@id': 'https://studiotreinointeligente.com.br/pilates/#service-pilates' },
        { '@id': 'https://studiotreinointeligente.com.br/musculacao/#service' },
        { '@id': 'https://studiotreinointeligente.com.br/treino-funcional/#service' },
        { '@id': 'https://studiotreinointeligente.com.br/yoga/#service' },
        { '@id': 'https://studiotreinointeligente.com.br/krav-maga/#service' },
      ],
    },
    { '@type': 'WebSite', '@id': 'https://studiotreinointeligente.com.br/#website', 'url': 'https://studiotreinointeligente.com.br/', 'name': 'Studio Livel Treino Inteligente', 'inLanguage': 'pt-BR' },
  ],
};

// Blog posts (paginas educacionais)
const allCollections = await Promise.all([
  getCollection('pilates'),
  getCollection('musculacao'),
  getCollection('funcional'),
  getCollection('yoga'),
  getCollection('krav-maga'),
]);
const blogPosts = allCollections.flat()
  .filter(e => e.data.type === 'educacional')
  .slice(0, 3);

const modalidades = [
  {
    href: '/musculacao/', cor: 'roxo', andar: '1 Andar',
    nome: 'Musculacao', img: '/images/modalidades/musculacao-mulher.webp',
    alt: 'Mulher treinando musculacao com halteres no Studio Livel',
    desc: 'Forca, hipertrofia e composicao corporal com o Metodo Livel. Ciclos de 3 semanas. 45 minutos por sessao.',
    tag: '1 Andar · Forca',
  },
  {
    href: '/pilates/', cor: 'gold', andar: '2 Andar',
    nome: 'Pilates', img: '/images/modalidades/pilates-turma.webp',
    alt: 'Turma de Pilates mat com mulheres em exercicio — Studio Livel',
    desc: 'Mobilidade, postura e ativacao profunda. Equipamentos Reformer, Cadillac e Chair. 50 minutos por sessao.',
    tag: '2 Andar · Postura',
  },
  {
    href: '/treino-funcional/', cor: 'orange', andar: '3 Andar',
    nome: 'Funcional FitBox', img: '/images/modalidades/funcional-mulher.webp',
    alt: 'Mulher em treino funcional em grupo no Studio Livel',
    desc: 'Circuitos funcionais em grupo com Kit FitBox. 30 minutos de alta eficiencia.',
    tag: '3 Andar · Grupo',
  },
  {
    href: '/yoga/', cor: 'gray', andar: 'Studio',
    nome: 'Yoga', img: '/images/modalidades/yoga3.webp',
    alt: 'Mulher praticando Yoga — meditacao e respiracao consciente',
    desc: 'Asanas, respiracao e presenca. Pratica estruturada com progressao pelo Metodo Livel.',
    tag: 'Equilibrio e presenca',
  },
  {
    href: '/krav-maga/', cor: 'red', andar: 'Studio',
    nome: 'Krav Maga', img: '/images/modalidades/krav-maga-treino.webp',
    alt: 'Mulher treinando Krav Maga — golpe no saco com foco e determinacao',
    desc: 'Defesa pessoal civil com condicionamento fisico integrado. Aberto a iniciantes.',
    tag: 'Defesa pessoal',
  },
];
---

<BaseLayout
  title="Studio Livel Treino Inteligente | Prado, Belo Horizonte"
  description="Studio Livel Treino Inteligente: casa especializada em treino acompanhado desde 1986 no Prado, BH. Pilates, Musculacao, Funcional, Yoga e Krav Maga. Turmas de 6 alunos."
  canonical="https://studiotreinointeligente.com.br/"
  schema={schema}
  andar="roxo"
  activePath="/"
  lcpImage="/images/banner/fachada-banner-800w.avif"
>

  <!-- ────────────────────────────────────────────────
       HERO PRINCIPAL — Banner com imagem real
  ──────────────────────────────────────────────── -->
  <section class="home-hero" aria-labelledby="home-h1">
    <picture class="home-hero__bg" aria-hidden="true">
      <source type="image/avif" srcset="/images/banner/fachada-banner-400w.avif 400w, /images/banner/fachada-banner-800w.avif 800w, /images/banner/fachada-banner-1200w.avif 1200w" sizes="100vw" />
      <source type="image/webp" srcset="/images/banner/fachada-banner-400w.webp 400w, /images/banner/fachada-banner-800w.webp 800w, /images/banner/fachada-banner-1200w.webp 1200w" sizes="100vw" />
      <img src="/images/banner/fachada-banner.jpg" alt="" width="1200" height="800" loading="eager" decoding="sync" fetchpriority="high" />
    </picture>
    <div class="home-hero__overlay"></div>
    <div class="home-hero__noise"></div>

    <div class="wrap home-hero__inner">
      <p class="home-hero__kicker">Prado, Belo Horizonte · Desde 1986</p>
      <h1 id="home-h1" class="home-hero__h1">
        Studio Livel<br />
        <em>Treino Inteligente.</em>
      </h1>
      <p class="home-hero__sub">Casa especializada em treino acompanhado. Cinco modalidades. Turmas de ate 6 alunos por instrutor. Metodo Livel com ciclos de 3 semanas.</p>

      <div class="home-hero__btns">
        <a href="https://wa.me/5531991070392?text=Ol%C3%A1!%20Gostaria%20de%20agendar%20minha%20aula-avalia%C3%A7%C3%A3o%20gratuita%20no%20Studio%20Livel." class="btn btn--roxo btn--lg" target="_blank" rel="noopener noreferrer">Agendar pelo WhatsApp</a>
        <a href="/quem-somos/" class="btn btn--outline-white btn--lg">Conhecer o Estudio</a>
      </div>

      <div class="home-hero__stats">
        <div class="home-hero__stat"><span class="home-stat-n">38+</span><span class="home-stat-l">Anos de operacao</span></div>
        <div class="home-hero__stat"><span class="home-stat-n">6</span><span class="home-stat-l">Alunos por instrutor</span></div>
        <div class="home-hero__stat"><span class="home-stat-n">5</span><span class="home-stat-l">Modalidades</span></div>
        <div class="home-hero__stat"><span class="home-stat-n">4.8</span><span class="home-stat-l">No Google (201 avaliacoes)</span></div>
      </div>
    </div>
  </section>

  <!-- ────────────────────────────────────────────────
       SOBRE — O Studio
  ──────────────────────────────────────────────── -->
  <section class="home-sobre" aria-labelledby="sobre-heading">
    <div class="wrap home-sobre__inner">
      <div class="home-sobre__text">
        <p class="sec-kicker">O Estudio</p>
        <h2 id="sobre-heading" class="sec-h2">38 anos no <em>mesmo endereco.</em></h2>

<p class="sec-p">Fundado em 1986 no bairro do Prado, o Studio Livel Treino Inteligente e uma casa especializada em treino acompanhado. Nao e uma academia de volume: e um estudio com metodo proprio, educadores fisicos formados e turmas que nunca ultrapassam 6 alunos por instrutor.</p>
        <p class="sec-p">O Metodo Livel, formalizado em 2016 pela segunda geracao da familia, organiza a progressao em ciclos de 3 semanas com reavaliacao obrigatoria ao final de cada mesociclo. A validacao cientifica pelo American College of Sports Medicine (ACSM) esta em andamento para publicacao em 2026.</p>
        <div class="home-sobre__links">
          <a href="/quem-somos/" class="link-arrow">Conhecer a historia completa</a>
          <a href="/metodo-livel/" class="link-arrow">Entender o Metodo Livel</a>
        </div>
      </div>
      <div class="home-sobre__img">
        <picture>
          <source type="image/avif" srcset="/images/banner/foto-herbert-400w.avif 400w, /images/banner/foto-herbert-800w.avif 800w" sizes="(max-width:900px) 100vw, 50vw" />
          <source type="image/webp" srcset="/images/banner/foto-herbert-400w.webp 400w, /images/banner/foto-herbert-800w.webp 800w" sizes="(max-width:900px) 100vw, 50vw" />
          <img src="/images/banner/foto-herbert.jpg" alt="Professor do Studio Livel em sessao de treino" width="600" height="700" loading="lazy" decoding="async" />
        </picture>
      </div>
    </div>
  </section>

  <!-- ────────────────────────────────────────────────
       MODALIDADES
  ──────────────────────────────────────────────── -->
  <section class="home-modal" id="modalidades" aria-labelledby="modal-heading">
    <div class="wrap">
      <p class="sec-kicker">Cinco modalidades</p>
      <h2 id="modal-heading" class="sec-h2">Um estudio, <em>cinco praticas.</em></h2>
      <p class="sec-desc">Cada modalidade tem sala dedicada, instrutor de formacao especifica e progressao pelo Metodo Livel. Podem ser combinadas ao longo da semana.</p>

      <div class="modal-grid">
        {modalidades.map((m, i) => (
          <a href={m.href} class="modal-card anim" style={`animation-delay:${i * 0.07}s`}>
            <div class="modal-card__img-wrap">
              <picture>
                <source type="image/avif" srcset={m.img.replace('.webp', '-400w.avif') + ' 400w, ' + m.img.replace('.webp','-800w.avif') + ' 800w'} sizes="(max-width:640px) 100vw, 33vw" />
                <source type="image/webp" srcset={m.img.replace('.webp', '-400w.webp') + ' 400w, ' + m.img + ' 800w'} sizes="(max-width:640px) 100vw, 33vw" />
                <img src={m.img} alt={m.alt} width="400" height="280" loading="lazy" decoding="async" />
              </picture>
              <div class="modal-card__overlay"></div>
              <span class="modal-card__andar">{m.andar}</span>
            </div>
            <div class="modal-card__body">
              <span class="modal-card__tag">{m.tag}</span>
              <h3 class="modal-card__name">{m.nome}</h3>
              <p class="modal-card__desc">{m.desc}</p>
              <span class="modal-card__cta">Ver a modalidade &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ────────────────────────────────────────────────
       PARCEIROS
  ──────────────────────────────────────────────── -->
  <section class="home-partners" aria-label="Parceiros corporativos">
    <div class="wrap home-partners__inner">
      <p class="home-partners__label">Parceiros corporativos</p>
      <div class="home-partners__logos" aria-label="Wellhub, TotalPass e ClassPass">
        <img src="/images/selos/wellhub-magenta.png" alt="Wellhub parceiro" width="90" height="26" loading="lazy" decoding="async" />
        <img src="/images/selos/totalpass-white.svg" alt="TotalPass parceiro" width="90" height="26" loading="lazy" decoding="async" />
        <img src="/images/selos/classpass.svg" alt="ClassPass parceiro" width="80" height="26" loading="lazy" decoding="async" />
      </div>
      <p class="home-partners__note">Alunos com plano Wellhub, TotalPass ou ClassPass tem acesso ao estudio pelo beneficio corporativo.</p>
    </div>
  </section>

  <!-- ────────────────────────────────────────────────
       BLOG PREVIEW
  ──────────────────────────────────────────────── -->
  {blogPosts.length > 0 && (
    <section class="home-blog" aria-labelledby="blog-heading">
      <div class="wrap">
        <p class="sec-kicker">Blog e Educacao</p>
        <h2 id="blog-heading" class="sec-h2">Aprenda sobre <em>treino inteligente.</em></h2>
        <div class="blog-grid">
          {blogPosts.map(post => (
            <a href={`/${post.data.urlPath.replace(/^\/|\/$/g,'')}/`} class="blog-card">
              <div class="blog-card__modal">{post.data.modalidade}</div>
              <h3 class="blog-card__title">{post.data.title.split('|')[0].trim()}</h3>
              <p class="blog-card__desc">{post.data.description.substring(0, 110)}...</p>
              <span class="blog-card__link">Ler artigo &rarr;</span>
            </a>
          ))}
        </div>
        <div style="margin-top:28px;text-align:center">
          <a href="/blog/" class="btn btn--outline">Ver todos os artigos</a>
        </div>
      </div>
    </section>
  )}

  <!-- CTA e gerenciado globalmente pelo PreFooterCTA no BaseLayout -->

</BaseLayout>

<style>
/* ── Hero ───────────────────────────────────────── */
.home-hero {
  position: relative; overflow: hidden; min-height: 620px;
  display: flex; align-items: center;
}
.home-hero__bg {
  position: absolute; inset: 0; z-index: 0;
  pointer-events: none;
}
.home-hero__bg img {
  position: absolute; inset: 0; width: 100%; height: 100%;
  object-fit: cover; object-position: center;
  pointer-events: none;
}
.home-hero__overlay {
  position: absolute; inset: 0; z-index: 1;
  background: linear-gradient(135deg, rgba(30,5,40,.82) 0%, rgba(30,5,40,.55) 60%, rgba(30,5,40,.40) 100%);
  pointer-events: none;
}
.home-hero__noise {
  position: absolute; inset: 0; z-index: 2;
  background-image: radial-gradient(circle, rgba(255,255,255,.025) 1px, transparent 1px);
  background-size: 22px 22px; pointer-events: none;
}
.home-hero__inner { position: relative; z-index: 3; padding: 80px 32px; text-align: left; width: 100%; }
.home-hero__kicker { font-size: 11px; font-weight: 700; letter-spacing: .17em; text-transform: uppercase; color: var(--gold-light); margin-bottom: 20px; text-align: left; }
.home-hero__h1 {
  font-family: var(--font-display); font-size: clamp(36px, 6vw, 68px);
  font-weight: 900; text-transform: uppercase; letter-spacing: -0.01em;
  line-height: 1.0; color: #F0EDE8; margin-bottom: 18px; text-align: left;
}
.home-hero__h1 em { color: var(--gold-light); font-weight: 700; font-size: inherit; font-style: normal; }
.home-hero__sub { font-size: 17px; color: rgba(240,237,232,.62); line-height: 1.7; max-width: 560px; margin-bottom: 32px; text-align: left; margin-left: 0; }
.home-hero__btns { display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 48px; justify-content: flex-start; }
.home-hero__stats {
  display: flex; gap: 32px; flex-wrap: wrap; justify-content: flex-start;
  padding-top: 28px; border-top: 1px solid rgba(212,160,23,.25);
}
.home-hero__stat { display: flex; flex-direction: column; gap: 3px; }
.home-stat-n { font-family: var(--font-display); font-size: 32px; font-weight: 900; color: #F0EDE8; line-height: 1; }
.home-stat-l { font-size: 12px; color: rgba(240,237,232,.40); letter-spacing: .04em; }

/* ── Sobre ──────────────────────────────────────── */
.home-sobre { background: #fff; padding: 80px 0; }
.home-sobre__inner { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center; }
.home-sobre__img { border-radius: var(--r-xl); overflow: hidden; box-shadow: 0 16px 48px rgba(0,0,0,.12); }
.home-sobre__img img { width: 100%; height: auto; }
.home-sobre__links { display: flex; flex-direction: column; gap: 10px; margin-top: 28px; }


.link-arrow { font-size: 15px; font-weight: 600; color: var(--roxo); text-decoration: none; display: flex; align-items: center; gap: 6px; }
.link-arrow:hover { color: var(--roxo-dark); }
.link-arrow::after { content: ' →'; }

/* ── Modalidades ────────────────────────────────── */
.home-modal { background: var(--surface-subtle, #F2EFE8); padding: 80px 0; }
.modal-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 40px; }
.modal-card {
  background: #fff; border-radius: var(--r-xl); overflow: hidden; text-decoration: none;
  box-shadow: var(--shadow-sm); transition: transform .2s, box-shadow .2s;
  display: flex; flex-direction: column;
}
.modal-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); }
.modal-card__img-wrap { position: relative; aspect-ratio: 4/3; overflow: hidden; }
.modal-card__img-wrap picture { position: absolute; inset: 0; }
.modal-card__img-wrap img { width: 100%; height: 100%; object-fit: cover; transition: transform .4s; }
.modal-card:hover .modal-card__img-wrap img { transform: scale(1.04); }
.modal-card__overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,.45) 0%, transparent 60%); pointer-events: none; }
.modal-card__andar {
  position: absolute; bottom: 12px; left: 12px;
  font-size: 10px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase;
  background: rgba(0,0,0,.55); color: #fff; padding: 3px 10px; border-radius: 9999px;
}
.modal-card__body { padding: 20px 22px 24px; flex: 1; display: flex; flex-direction: column; }
.modal-card__tag { font-size: 10.5px; font-weight: 700; letter-spacing: .09em; text-transform: uppercase; color: var(--roxo); margin-bottom: 7px; }
.modal-card__name { font-family: var(--font-display); font-size: 22px; font-weight: 800; text-transform: uppercase; letter-spacing: -0.01em; color: var(--text); margin-bottom: 8px; }
.modal-card__desc { font-size: 13.5px; color: var(--text-dim); line-height: 1.6; flex: 1; margin-bottom: 14px; }
.modal-card__cta { font-size: 13px; font-weight: 600; color: var(--roxo); }

/* ── Parceiros ──────────────────────────────────── */
.home-partners { background: #fff; padding: 40px 0; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
.home-partners__inner { display: flex; align-items: center; gap: 32px; flex-wrap: wrap; justify-content: center; }
.home-partners__label { font-size: 11px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: var(--text-dim); }
.home-partners__logos { display: flex; gap: 24px; align-items: center; flex-wrap: wrap; }
.home-partners__logos img { height: 26px; width: auto; opacity: .65; filter: grayscale(1); transition: all .2s; }
.home-partners__logos img:hover { opacity: 1; filter: none; }
.home-partners__note { font-size: 13px; color: var(--text-dim); max-width: 320px; line-height: 1.5; text-align: center; }

/* ── Blog ───────────────────────────────────────── */
.home-blog { background: #fff; padding: 80px 0; }
.blog-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 36px; }
.blog-card {
  background: #fff; border: 1.5px solid var(--border); border-radius: var(--r-lg);
  padding: 24px; text-decoration: none; display: flex; flex-direction: column;
  transition: border-color .2s, box-shadow .2s;
}
.blog-card:hover { border-color: var(--roxo); box-shadow: 0 4px 16px rgba(99,36,101,.10); }
.blog-card__modal { font-size: 10.5px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--roxo); margin-bottom: 10px; }
.blog-card__title { font-size: 17px; font-weight: 700; color: var(--text); margin-bottom: 10px; line-height: 1.35; }
.blog-card__desc { font-size: 13.5px; color: var(--text-dim); line-height: 1.6; flex: 1; margin-bottom: 16px; }
.blog-card__link { font-size: 13px; font-weight: 600; color: var(--roxo); }

/* ── CTA Final ──────────────────────────────────── */
/* home-cta removido — PreFooterCTA global gerencia o CTA acima do footer */

/* ── Comuns ─────────────────────────────────────── */
.sec-kicker { font-size: 11px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--roxo); margin-bottom: 10px; }
.sec-h2 { font-family: var(--font-display); font-size: clamp(24px, 3.5vw, 40px); font-weight: 800; text-transform: uppercase; letter-spacing: -0.01em; color: var(--text); margin-bottom: 12px; line-height: 1.08; }
.sec-h2 em { font-style: normal; color: var(--roxo); font-weight: 700; font-size: inherit; }
.sec-desc { font-size: 16px; color: var(--text-dim); line-height: 1.7; max-width: 580px; }
.sec-p { font-size: 16px; color: var(--text-dim); line-height: 1.78; margin-bottom: 14px; }

/* ── Responsive ─────────────────────────────────── */
@media(max-width:1000px) { .modal-grid { grid-template-columns: repeat(2, 1fr); } .blog-grid { grid-template-columns: repeat(2, 1fr); } }
@media(max-width:860px)  { .home-sobre__inner { grid-template-columns: 1fr; gap: 36px; } .home-sobre__img { order: -1; } }
@media(max-width:640px)  {
  .home-hero { min-height: 520px; }
  .home-hero__inner { padding: 60px 18px; }
  .home-hero__stats { gap: 20px; }
  .home-hero__btns { flex-direction: column; }
  .home-hero__btns .btn { width: 100%; justify-content: center; }
  .modal-grid { grid-template-columns: 1fr; }
  .blog-grid { grid-template-columns: 1fr; }
  .home-partners__inner { flex-direction: column; gap: 16px; }
}
</style>
