---
interface BreadcrumbItem {
  name: string;
  item: string;
}
interface Props {
  items: BreadcrumbItem[];
}
const { items } = Astro.props;
---
<nav aria-label="Breadcrumb" class="breadcrumb-nav">
  <ol class="breadcrumb" itemscope itemtype="https://schema.org/BreadcrumbList" role="list">
    {items.map((crumb, i) => (
      <li
        itemprop="itemListElement"
        itemscope
        itemtype="https://schema.org/ListItem"
        class="breadcrumb__item"
      >
        {i < items.length - 1 ? (
          <a href={crumb.item} itemprop="item">
            <span itemprop="name">{crumb.name}</span>
          </a>
        ) : (
          <span itemprop="name" aria-current="page">{crumb.name}</span>
        )}
        <meta itemprop="position" content={String(i + 1)} />
        {i < items.length - 1 && <span class="breadcrumb__sep" aria-hidden="true">/</span>}
      </li>
    ))}
  </ol>
</nav>

<style>
.breadcrumb-nav { margin-bottom: 24px; }
.breadcrumb { list-style: none; display: flex; flex-wrap: wrap; gap: 4px; align-items: center; }
.breadcrumb__item {
  display: flex; align-items: center; gap: 4px;
  font-size: 12.5px; color: var(--text-faint);
  min-width: 0;
}
.breadcrumb__item a { color: var(--text-faint); text-decoration: none; }
.breadcrumb__item a:hover { color: var(--roxo); text-decoration: underline; }
.breadcrumb__item span[aria-current] { color: var(--text-dim); }
.breadcrumb__sep { color: var(--border-strong); }
</style>
