---
interface Bairro { label: string; href: string; }
interface Props {
  bairros: Bairro[];
  andar?: 'roxo' | 'gold' | 'orange' | 'gray' | 'red' | 'none';
}
const { bairros, andar = 'roxo' } = Astro.props;

const accentHex = {
  roxo: '#632465', gold: '#D4A017',
  orange: '#FF914D', gray: '#6B7280',
  red: '#C0181A', none: '#632465',
}[andar];

const coordsMap: Record<string, [number, number]> = {
  'Prado':           [-19.9251, -43.9652],
  'Santo Agostinho': [-19.9265, -43.9468],
  'Barro Preto':     [-19.9291, -43.9534],
  'Padre Eustaquio': [-19.9098, -43.9738],
  'Caicara':         [-19.9052, -43.9660],
  'Barroca':         [-19.9362, -43.9705],
  'Nova Suica':      [-19.9340, -43.9450],
  'Alto Barroca':    [-19.9440, -43.9714],
  'Carlos Prates':   [-19.9145, -43.9605],
  'California':      [-19.9022, -43.9588],
  'Calafate':        [-19.9178, -43.9820],
  'Gutierrez':       [-19.9428, -43.9828],
};

const distMap: Record<string, string> = {
  'Prado': 'Sede', 'Santo Agostinho': '1 km',
  'Barro Preto': '1,2 km', 'Padre Eustaquio': '1,5 km',
  'Caicara': '2 km', 'Barroca': '1,8 km',
  'Nova Suica': '2,8 km', 'Alto Barroca': '2,2 km',
  'Carlos Prates': '2,5 km', 'California': '3 km',
  'Calafate': '3,2 km', 'Gutierrez': '3,5 km',
};

const mapData = JSON.stringify({
  accent: accentHex,
  studio: { lat: -19.9251, lng: -43.9652 },
  bairros: bairros
    .map(b => ({
      label: b.label,
      href:  b.href,
      lat:   coordsMap[b.label]?.[0] ?? 0,
      lng:   coordsMap[b.label]?.[1] ?? 0,
      dist:  distMap[b.label] ?? '',
    }))
    .filter(b => b.lat !== 0),
});
---

<section class="bmap-section" aria-labelledby="bmap-heading">
  <div class="wrap">
    <div class="bmap-header">
      <div class="bmap-header__text">
        <p class="bmap-kicker" style={`color:${accentHex}`}>Localização</p>
        <h2 id="bmap-heading" class="bmap-title">Como chegar no Studio Livel</h2>
        <p class="bmap-desc">
          R. Chopin, 271, Prado, Belo Horizonte. Abra o Google Maps para traçar a rota
          a partir da sua localização atual.
        </p>
      </div>
      <a
        href="https://www.google.com/maps/dir/?api=1&destination=-19.9251,-43.9652&destination_place_id=Studio+Livel+Treino+Inteligente"
        target="_blank"
        rel="noopener noreferrer"
        class="bmap-gmaps-btn"
        style={`--btn-c:${accentHex}`}
        aria-label="Abrir rotas no Google Maps para o Studio Livel"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M3 12h18M12 3l9 9-9 9"/>
        </svg>
        Traçar rota no Google Maps
      </a>
    </div>

    <!-- bmap-clip: arredonda visualmente sem clipar eventos de clique do popup -->
    <div class="bmap-clip">
      <div
        class="bmap-wrap"
        id="bairros-map"
        data-map={mapData}
        aria-label="Mapa de localização do Studio Livel"
        aria-busy="true"
      >
        <!-- Skeleton visível enquanto Leaflet carrega -->
        <div class="bmap-skeleton" aria-hidden="true">
          <div class="bmap-skeleton__pin"></div>
          <div class="bmap-skeleton__label">Carregando mapa…</div>
        </div>
      </div>
    </div>

    <ul class="bmap-pills" role="list">
      {bairros.map(b => {
        const dist = distMap[b.label];
        return (
          <li>
            <a href={b.href} class="bmap-pill" style={`--pc:${accentHex}`}>
              {b.label}
              {dist && <span class="bmap-pill__d">{dist}</span>}
            </a>
          </li>
        );
      })}
    </ul>
  </div>
</section>

<!-- Leaflet carregado apenas quando o mapa entra no viewport -->
<script>
document.addEventListener('DOMContentLoaded', () => {
  const el = document.getElementById('bairros-map');
  if (!el) return;

  const io = new IntersectionObserver(async ([entry]) => {
    if (!entry.isIntersecting) return;
    io.disconnect();

    const raw = el.getAttribute('data-map');
    if (!raw) return;

    let cfg: {
      accent: string;
      studio: { lat: number; lng: number };
      bairros: Array<{ label: string; href: string; lat: number; lng: number; dist: string }>;
    };
    try { cfg = JSON.parse(raw); } catch { return; }
    el.removeAttribute('data-map');

    // Injetar CSS do Leaflet de forma não-bloqueante
    const link = document.createElement('link');
    link.rel = 'stylesheet';
    link.href = '/leaflet.css';
    document.head.appendChild(link);
    await new Promise<void>(r => { link.onload = () => r(); link.onerror = () => r(); });

    // Import dinâmico — Vite cria chunk separado, carregado só aqui
    const { default: L } = await import('leaflet');

    // Limpar skeleton e inicializar mapa
    el.innerHTML = '';
    el.removeAttribute('aria-busy');

    const map = L.map(el, {
      center:             [cfg.studio.lat, cfg.studio.lng],
      zoom:               13,
      scrollWheelZoom:    false,
      attributionControl: true,
      closePopupOnClick:  false, // não fecha popup ao clicar fora — evita interferência
      tap:                false,  // desativa tap handler do Leaflet no mobile (conflito com links)
    });

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
      maxZoom: 18,
    }).addTo(map);

    // Círculo de 5 km
    L.circle([cfg.studio.lat, cfg.studio.lng], {
      radius:      5000,
      color:       cfg.accent,
      fillColor:   cfg.accent,
      fillOpacity: 0.07,
      weight:      2,
      dashArray:   '10, 6',
    }).addTo(map);

    // Marcador principal do Studio
    const studioIcon = L.divIcon({
      html: `<div style="background:${cfg.accent};color:#fff;font-family:sans-serif;
        font-size:11px;font-weight:700;padding:5px 10px;border-radius:6px;
        white-space:nowrap;box-shadow:0 2px 8px rgba(0,0,0,.28);position:relative;">
        Livel Estúdio
        <span style="position:absolute;bottom:-6px;left:50%;transform:translateX(-50%);
          width:0;height:0;border-left:6px solid transparent;border-right:6px solid transparent;
          border-top:6px solid ${cfg.accent}"></span>
      </div>`,
      className:  '',
      iconSize:   [120, 36],
      iconAnchor: [60, 36],
    });

    const gmapsUrl = 'https://www.google.com/maps/dir/?api=1&destination=' +
      cfg.studio.lat + ',' + cfg.studio.lng;

    const studioMarker = L.marker([cfg.studio.lat, cfg.studio.lng], { icon: studioIcon, zIndexOffset: 1000 })
      .addTo(map)
      .bindPopup(
        '<strong>Studio Livel Treino Inteligente</strong><br>' +
        'R. Chopin, 271, Prado, BH<br>' +
        '<small style="color:#888">(31) 99107-0392</small><br><br>' +
        '<a href="' + gmapsUrl + '" target="_blank" rel="noopener noreferrer" ' +
        'onclick="event.stopPropagation()" ' +
        'style="display:inline-flex;align-items:center;gap:6px;background:' + cfg.accent + ';' +
        'color:#fff;padding:7px 14px;border-radius:6px;text-decoration:none;' +
        'font-weight:600;font-size:13px;margin-top:4px">' +
        '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">' +
        '<path d="M3 12h18M12 3l9 9-9 9"/></svg>' +
        'Traçar rota</a>'
      , { maxWidth: 220, autoPan: true })
      .openPopup();

    // Marcadores dos bairros
    cfg.bairros.forEach(b => {
      if (b.label === 'Prado' || !b.lat) return;

      const icon = L.divIcon({
        html: `<div style="width:12px;height:12px;background:#fff;
          border:2.5px solid ${cfg.accent};border-radius:50%;
          box-shadow:0 1px 4px rgba(0,0,0,.2)"></div>`,
        className:  '',
        iconSize:   [12, 12],
        iconAnchor: [6, 6],
      });

      L.marker([b.lat, b.lng], { icon })
        .addTo(map)
        .bindPopup(
          `<strong>${b.label}</strong><br>` +
          `<span style="color:#888;font-size:12px">${b.dist} do estúdio</span><br>` +
          `<a href="${b.href}" onclick="event.stopPropagation()" ` +
          `style="color:${cfg.accent};font-weight:600;font-size:12px;text-decoration:none">` +
          `Ver página &#8594;</a>`
        , { autoPan: true });
    });

    // Ajusta bounds para cobrir todos os marcadores
    const allLatLngs: [number, number][] = cfg.bairros
      .filter(b => b.lat !== 0)
      .map(b => [b.lat, b.lng]);

    if (allLatLngs.length > 0) {
      map.fitBounds(allLatLngs, { padding: [50, 50], maxZoom: 13 });
    }
  }, { rootMargin: '300px 0px' });

  io.observe(el);
});
</script>

<style>
.bmap-section { padding: 56px 0; background: #fff; border-top: 1px solid var(--border); }
.bmap-kicker  { font-size: 11px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; margin-bottom: 10px; }
.bmap-title   { font-family: var(--font-display); font-size: clamp(22px,2.8vw,34px); font-weight: 400; color: var(--text); margin-bottom: 8px; line-height: 1.15; }
.bmap-desc    { font-size: 15px; color: var(--text-dim); max-width: 540px; line-height: 1.65; }

.bmap-header {
  display: flex; align-items: flex-end; justify-content: space-between;
  gap: 24px; flex-wrap: wrap; margin-bottom: 24px;
}
.bmap-header__text { flex: 1; min-width: 0; }

.bmap-gmaps-btn {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 12px 22px; border-radius: 9999px;
  background: var(--btn-c, var(--roxo)); color: #fff;
  font-size: 14px; font-weight: 600; text-decoration: none;
  white-space: nowrap; flex-shrink: 0;
  box-shadow: 0 2px 12px rgba(0,0,0,.15);
  transition: opacity .15s, transform .15s;
}
.bmap-gmaps-btn:hover { opacity: .88; transform: translateY(-1px); }
@media (max-width: 600px) {
  .bmap-header { flex-direction: column; align-items: flex-start; }
  .bmap-gmaps-btn { width: 100%; justify-content: center; }
}

/* Wrapper que faz o clip visual com border-radius — não afeta eventos de clique */
.bmap-clip {
  width: 100%;
  border-radius: var(--r-xl);
  overflow: hidden;
  box-shadow: var(--shadow-md);
  border: 1px solid var(--border);
  margin-bottom: 20px;
  isolation: isolate; /* contém z-indexes do Leaflet, não conflita com o nav */
}

/* Container real do Leaflet — overflow visible para popups funcionarem */
.bmap-wrap {
  width: 100%; height: 460px;
  background: #f0ede6;
  position: relative;
  overflow: visible;
}
@media (max-width: 768px) { .bmap-wrap { height: 380px; } }
@media (max-width: 480px) { .bmap-wrap { height: 300px; } }

/* Skeleton enquanto Leaflet carrega */
.bmap-skeleton {
  position: absolute; inset: 0;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center; gap: 14px;
  background: #f0ede6;
  animation: bmap-pulse 1.8s ease-in-out infinite;
}
.bmap-skeleton__pin {
  width: 32px; height: 32px;
  border-radius: 50% 50% 50% 0;
  transform: rotate(-45deg);
  background: rgba(99,36,101,0.25);
}
.bmap-skeleton__label {
  font-size: 13px; color: rgba(99,36,101,0.45);
  letter-spacing: 0.04em;
}
@keyframes bmap-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.55; }
}

.bmap-pills  { list-style: none; display: flex; flex-wrap: wrap; gap: 8px; }
.bmap-pill   {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 7px 14px; border-radius: 9999px;
  border: 1.5px solid var(--border-strong);
  font-size: 13.5px; font-weight: 500; color: var(--text-dim);
  text-decoration: none; background: #fff;
  transition: border-color .15s, color .15s;
}
.bmap-pill:hover { border-color: var(--pc); color: var(--pc); }
.bmap-pill__d { font-size: 11px; color: var(--text-faint); font-family: var(--font-mono); }
</style>
