---
interface Props {
  overline: string;
  h1: string;
  intro: string;
  andar: 'roxo' | 'gold' | 'orange';
  stats?: Array<{ num: string; label: string }>;
  ctaPrimary?: { href: string; label: string };
  ctaSecondary?: { href: string; label: string };
  imageSrc?: string;
  imageAlt?: string;
  imageWidth?: number;
  imageHeight?: number;
  isLCP?: boolean;
}

const {
  overline, h1, intro, andar,
  stats = [],
  ctaPrimary = { href: '/aula-avaliacao/', label: 'Agendar Aula-Avaliação' },
  ctaSecondary,
  imageSrc, imageAlt = '', imageWidth = 1200, imageHeight = 630,
  isLCP = true,
} = Astro.props;

const heroClass = { roxo: 'hero--roxo', gold: 'hero--gold', orange: 'hero--orange' }[andar];
const overlineClass = { roxo: 'hero__overline--roxo', gold: 'hero__overline--gold', orange: 'hero__overline--orange' }[andar];
const statsClass = { roxo: 'hero__stats--roxo', gold: 'hero__stats--gold', orange: 'hero__stats--orange' }[andar];
const btnClass = { roxo: 'btn--roxo', gold: 'btn--gold', orange: 'btn--orange' }[andar];
const emClass = { roxo: 'em-roxo', gold: 'em-gold', orange: 'em-orange' }[andar];
---

<section class={`hero ${heroClass}`} aria-labelledby="hero-h1">
  <div class="wrap hero__inner">
    <div class="hero__content">
      <p class={`hero__overline ${overlineClass}`}>{overline}</p>
      <h1 id="hero-h1" class="hero__h1" set:html={h1.replace(/\*(.*?)\*/g, `<em class="${emClass}">$1</em>`)} />
      <p class="hero__p">{intro}</p>
      <div class="hero__btns">
        <a href={ctaPrimary.href} class={`btn ${btnClass} btn--lg`}>{ctaPrimary.label}</a>
        {ctaSecondary && (
          <a href={ctaSecondary.href} class="btn btn--ghost">{ctaSecondary.label}</a>
        )}
      </div>
      {stats.length > 0 && (
        <div class={`hero__stats ${statsClass}`}>
          {stats.map(s => (
            <div class="hero__stat">
              <span class="hero__stat-num">{s.num}</span>
              <span class="hero__stat-label">{s.label}</span>
            </div>
          ))}
        </div>
      )}
    </div>

    {imageSrc && (
      <div class="hero__img-wrap">
        <picture>
          <source type="image/avif" srcset={`${imageSrc.replace(/\.(jpg|jpeg|png|webp)$/i, '.avif')}`} />
          <source type="image/webp" srcset={`${imageSrc.replace(/\.(jpg|jpeg|png)$/i, '.webp')}`} />
          <img
            src={imageSrc}
            alt={imageAlt}
            width={imageWidth}
            height={imageHeight}
            loading={isLCP ? 'eager' : 'lazy'}
            decoding={isLCP ? 'sync' : 'async'}
            fetchpriority={isLCP ? 'high' : 'auto'}
          />
        </picture>
      </div>
    )}
  </div>
</section>

<style>
.hero {
  padding: var(--sp-20) 0 var(--sp-16);
  position: relative; overflow: hidden;
}
.hero--roxo {
  background: #280828;
  background-image:
    radial-gradient(ellipse at 70% 50%, rgba(99,36,101,0.40) 0%, transparent 60%),
    radial-gradient(ellipse at 10% 80%, rgba(212,160,23,0.12) 0%, transparent 50%);
}
.hero--gold {
  background: #2A2208;
  background-image:
    radial-gradient(ellipse at 65% 40%, rgba(212,160,23,0.35) 0%, transparent 60%),
    radial-gradient(ellipse at 10% 90%, rgba(99,36,101,0.08) 0%, transparent 50%);
}
.hero--orange {
  background: #2E1408;
  background-image:
    radial-gradient(ellipse at 70% 50%, rgba(255,145,77,0.35) 0%, transparent 60%),
    radial-gradient(ellipse at 10% 80%, rgba(212,160,23,0.10) 0%, transparent 50%);
}
.hero::after {
  content: ''; position: absolute; inset: 0;
  background-image: radial-gradient(circle, rgba(255,255,255,0.03) 1px, transparent 1px);
  background-size: 24px 24px; pointer-events: none;
}
.hero__inner {
  position: relative; z-index: 1;
  display: grid; grid-template-columns: 1fr auto; gap: 48px; align-items: center;
}
.hero__content { max-width: 580px; min-width: 0; }
.hero__overline {
  font-size: 10.5px; font-weight: 700; letter-spacing: 0.17em; text-transform: uppercase;
  margin-bottom: var(--sp-5); display: flex; align-items: center; gap: 12px;
}
.hero__overline::before { content: ''; display: inline-block; width: 24px; height: 1.5px; }
.hero__overline--roxo   { color: var(--roxo-lighter); }
.hero__overline--roxo::before { background: var(--roxo-lighter); }
.hero__overline--gold   { color: var(--gold-light); }
.hero__overline--gold::before { background: var(--gold-light); }
.hero__overline--orange { color: var(--orange-lighter); }
.hero__overline--orange::before { background: var(--orange-lighter); }
.hero__h1 {
  font-family: var(--font-display); font-size: clamp(30px, 4vw, 50px);
  font-weight: 900; text-transform: uppercase; letter-spacing: -0.01em;
  line-height: 1.02; color: #F0EDE8;
  margin-bottom: var(--sp-5); overflow-wrap: break-word;
}
.em-roxo   { color: var(--roxo-lighter); font-weight: 700; font-size: inherit; }
.em-gold   { color: var(--gold-light);   font-weight: 700; font-size: inherit; }
.em-orange { color: var(--orange-lighter); font-weight: 700; font-size: inherit; }
.hero__p { font-size: 16.5px; color: rgba(240,237,232,0.58); line-height: 1.68; margin-bottom: var(--sp-10); max-width: 440px; overflow-wrap: break-word; }
.hero__btns { display: flex; gap: 12px; flex-wrap: wrap; }
.hero__stats { display: flex; gap: 40px; flex-wrap: wrap; margin-top: var(--sp-12); padding-top: var(--sp-8); }
.hero__stats--roxo   { border-top: 1px solid rgba(99,36,101,0.30); }
.hero__stats--gold   { border-top: 1px solid rgba(212,160,23,0.25); }
.hero__stats--orange { border-top: 1px solid rgba(255,145,77,0.25); }
.hero__stat { display: flex; flex-direction: column; gap: 3px; }
.hero__stat-num   { font-family: var(--font-display); font-size: 32px; font-weight: 900; color: #F0EDE8; line-height: 1; }
.hero__stat-label { font-size: 12px; color: rgba(240,237,232,0.38); letter-spacing: 0.04em; }
.hero__img-wrap { border-radius: var(--r-xl); overflow: hidden; box-shadow: var(--shadow-lg); flex-shrink: 0; max-width: 420px; }
.hero__img-wrap img { width: 100%; height: auto; }

/* Botões */
.btn { display: inline-flex; align-items: center; justify-content: center; gap: 7px; padding: 12px 26px; border-radius: 9999px; font-size: 14.5px; font-weight: 600; line-height: 1; text-decoration: none; border: 2px solid transparent; transition: background 0.18s, transform 0.15s; white-space: nowrap; }
.btn--lg  { padding: 15px 34px; font-size: 16.5px; }
.btn--roxo   { background: var(--roxo); color: #fff; border-color: var(--roxo); }
.btn--roxo:hover   { background: var(--roxo-dark); border-color: var(--roxo-dark); transform: translateY(-1px); box-shadow: 0 4px 18px rgba(99,36,101,0.40); }
.btn--gold   { background: var(--gold); color: var(--brown); border-color: var(--gold); }
.btn--gold:hover   { background: var(--gold-dark); color: #fff; border-color: var(--gold-dark); transform: translateY(-1px); box-shadow: 0 4px 18px rgba(212,160,23,0.40); }
.btn--orange { background: var(--orange); color: #fff; border-color: var(--orange); }
.btn--orange:hover { background: var(--orange-dark); border-color: var(--orange-dark); transform: translateY(-1px); box-shadow: 0 4px 18px rgba(255,145,77,0.42); }
.btn--ghost { background: transparent; border-color: rgba(192,144,192,0.40); color: rgba(240,237,232,0.80); }
.btn--ghost:hover { background: rgba(255,255,255,0.07); }

@media (max-width: 900px) { .hero__img-wrap { display: none; } .hero__inner { grid-template-columns: 1fr; } }
@media (max-width: 640px) { .hero { padding: var(--sp-12) 0; } }
</style>
