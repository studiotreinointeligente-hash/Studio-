---
interface Props {
  title?: string;
  subtitle?: string;
}
const {
  title = 'Aula de Avaliação Gratuita',
  subtitle = '50 minutos com um educador físico. Mapeamento de histórico, objetivos e nível. Programa definido ao final da sessão. Sem compromisso de plano.',
} = Astro.props;
---

<section class="prefooter-cta" aria-labelledby="prefooter-cta-heading">
  <div class="wrap prefooter-cta__inner">
    <div class="prefooter-cta__text">
      <p class="prefooter-cta__kicker">Comece pelo começo</p>
      <h2 id="prefooter-cta-heading" class="prefooter-cta__title">{title}</h2>
      <p class="prefooter-cta__sub">{subtitle}</p>
    </div>
    <div class="prefooter-cta__btns">
      <a href="/aula-avaliacao/" class="btn btn--roxo btn--lg">Agendar agora</a>
      <a href="/planos/" class="btn btn--outline btn--lg">Ver planos</a>
    </div>
  </div>
</section>

<style>
.prefooter-cta {
  background: var(--roxo-dark, #3D1540);
  padding: 64px 0;
  position: relative; overflow: hidden;
}
.prefooter-cta::before {
  content: ''; position: absolute; inset: 0;
  background-image: radial-gradient(circle, rgba(255,255,255,.025) 1px, transparent 1px);
  background-size: 22px 22px; pointer-events: none;
}
.prefooter-cta__inner {
  position: relative; z-index: 1;
  display: flex; align-items: center; justify-content: space-between;
  gap: 40px; flex-wrap: wrap;
}
.prefooter-cta__text { max-width: 560px; }
.prefooter-cta__kicker {
  font-size: 11px; font-weight: 700; letter-spacing: .16em; text-transform: uppercase;
  color: var(--gold-light, #E8C040); margin-bottom: 12px;
}
.prefooter-cta__title {
  font-family: var(--font-display); font-size: clamp(24px, 3.5vw, 40px);
  font-weight: 400; color: #F0EDE8; margin-bottom: 12px; line-height: 1.1;
}
.prefooter-cta__sub {
  font-size: 15.5px; color: rgba(240,237,232,.58); line-height: 1.7;
}
.prefooter-cta__btns {
  display: flex; gap: 14px; flex-wrap: wrap; flex-shrink: 0;
}
/* Sobrescreve .btn--outline para versao clara sobre fundo escuro */
.prefooter-cta .btn--outline {
  border-color: rgba(255,255,255,.45); color: #F0EDE8;
}
.prefooter-cta .btn--outline:hover {
  background: rgba(255,255,255,.10);
}
@media (max-width: 760px) {
  .prefooter-cta__inner { flex-direction: column; align-items: flex-start; }
  .prefooter-cta__btns { flex-direction: column; width: 100%; }
  .prefooter-cta__btns .btn { width: 100%; justify-content: center; }
}
</style>
